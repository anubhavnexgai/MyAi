# ╔══════════════════════════════════════════════════════════════════╗
# ║  MyAi — Personal AI Agent Configuration                        ║
# ║  Copy this to .env and fill in your details                     ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Your Identity (REQUIRED — personalizes the assistant) ──
MYAI_USER_NAME=Your Name
MYAI_USER_EMAIL=you@example.com
MYAI_USER_PHONE=+919876543210
MYAI_USER_ROLE=Software Engineer

# ── Ollama (REQUIRED — local LLM) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# ── Server ──
HOST=0.0.0.0
PORT=8001

# ── Security ──
ALLOWED_USERS=*

# ── Web Search ──
SEARCH_PROVIDER=duckduckgo
# Options: duckduckgo (free), tavily (API key required)
TAVILY_API_KEY=

# ── Storage ──
DATABASE_PATH=data/miai.db
CHROMA_PATH=data/chroma

# ── WhatsApp via Twilio (optional) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Slack (optional) ──
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# ── Microsoft 365 (optional: calendar, email, files) ──
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
GRAPH_REDIRECT_URI=http://localhost:8001/auth/callback

# ── NexgAI Platform (optional: enterprise agent gateway) ──
NEXGAI_ENABLED=false
NEXGAI_BASE_URL=
NEXGAI_TENANT_ID=
NEXGAI_SERVICE_USER=
NEXGAI_SERVICE_PASSWORD=

# ── AgentHub (optional) ──
AGENTHUB_ENABLED=false
AGENTHUB_BASE_URL=
AGENTHUB_API_KEY=

# ── Advanced ──
# Vision model (requires: ollama pull llava:7b)
# Heartbeat (proactive agent ticks)
MYAI_HEARTBEAT=off
MYAI_HEARTBEAT_INTERVAL=1800
# Self-learning loop
LEARNING_INTERVAL_HOURS=6
LEARNING_MIN_NEGATIVE_FEEDBACK=3
